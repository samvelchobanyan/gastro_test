{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/forms/**",
              "components/menu/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='DropdownOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<DropdownOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItemCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|price|currency|imageUrl|tag|quantity|onAdd|onQuantityChange|key|ref|className|style|children)$/]",
        "message": "<MenuItemCard> doesn't accept that prop. Declared props: name, description, price, currency, imageUrl, tag, quantity, onAdd, onQuantityChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|size|disabled|onChange|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, min, max, step, size, disabled, onChange, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Stepper> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "DropdownOption": {
